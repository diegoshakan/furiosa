<div>
  <h1 class="font-bold text-4xl">Hello World, I'm Furiosa!</h1>
  <p>Where am I? </p>

  <%= button_to "Criar Anúncio", new_announcement_path, class: "bg-blue-500 hover:bg-violet-700 text-white font-bold py-2 px-4 rounded-full" %>

  <div id="announcements" class="min-w-full">
    <% @announcements.each do |announcement| %>
      <div class="container w-screen mx-auto flex items-center justify-center">
        <div>
          <%= link_to announcement do %>
            <div class="flex flex-col bg-grey-700 shadow-lg shadow-grey-800 py-4 px-6 my-4 rounded-md">
              <div class="flex flex-row">
                <div cla>
                    <% if announcement.images.attached? %>
                      <%= image_tag announcement.images.first, class: "rounded-t-lg rounded-b-lg w-36" %>
                    <% end %>
                    <img class="rounded-t-lg" src="/docs/images/blog/image-1.jpg" alt="" />
                </div>

                <div class="flex flex-row">
                  <div class="ml-4">
                      <h5 class="text-2xl font-normal tracking-tight"><%= announcement.title %></h5>
                  </div>

                  <div class="ml-6">
                      <h5 class="ml-6 text-2xl font-semibold tracking-tight">R$ <%= announcement.value %></h5>
                  </div>
                </div>
              </div>

              <div class="text-end text-sm font-light">
                <%= time_ago_in_words announcement.created_at %>
              </div>
            </div>
          <% end %>
        </div>
      </div>

  <% end %>
  </div>
</div>
