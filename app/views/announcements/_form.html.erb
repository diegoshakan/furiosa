<%= form_with(model: announcement, class: "contents w-full max-w-lg") do |form| %>
  <div class="flex flex-wrap -mx-3 mb-6">
    <% if announcement.errors.any? %>
      <div id="error_explanation" class="bg-red-50 text-red-500 px-3 py-2 font-medium rounded-lg mt-3">
        <h2><%= pluralize(announcement.errors.count, "error") %> prohibited this announcement from being saved:</h2>

        <ul>
          <% announcement.errors.each do |error| %>
            <li><%= error.full_message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div class="w-full md:w-1/2 px-3 mb-6 md:mb-0">
      <%= form.label :title, class: "block uppercase tracking-wide text-gray-700 text-xs font-bold mb-2" %>
      <%= form.text_field :title, class: "appearance-none block w-full bg-gray-200 text-gray-700 border border-red-500 rounded py-3 px-4 mb-3 leading-tight focus:outline-none focus:bg-white" %>
    </div>

    <!--
    <div class="my-5">
      <%# form.label :code %>
      <%# form.text_field :code, class: "block shadow rounded-md border border-gray-200 outline-none px-3 py-2 mt-2 w-full" %>
    </div>
    -->

    <div class="w-full md:w-1/2 px-3 mb-6 md:mb-0">
      <%= form.label :description, class: "block uppercase tracking-wide text-gray-700 text-xs font-bold mb-2" %>
      <%= form.text_area :description, class: "appearance-none block w-full bg-gray-200 text-gray-700 border border-red-500 rounded py-3 px-4 mb-3 leading-tight focus:outline-none focus:bg-white" %>
    </div>

    <div class="w-full md:w-1/2 px-3 mb-6 md:mb-0">
      <%= form.label :value, class: "block uppercase tracking-wide text-gray-700 text-xs font-bold mb-2" %>
      <%= form.text_field :value, class: "appearance-none block w-full bg-gray-200 text-gray-700 border border-red-500 rounded py-3 px-4 mb-3 leading-tight focus:outline-none focus:bg-white" %>
    </div>

    <div class="w-full md:w-1/2 px-3 mb-6 md:mb-0">
      <%= form.label :category, class: "block uppercase tracking-wide text-gray-700 text-xs font-bold mb-2" %>
      <%= form.select :category_id, options_for_select(Category.all.pluck(:name, :id)), include_blank: true,
                     class: "appearance-none block w-full bg-gray-200 text-gray-700 border border-red-500 rounded py-3 px-4 mb-3 leading-tight focus:outline-none focus:bg-white" %>
    </div>

    <div class="w-full md:w-1/2 px-3 mb-6 md:mb-0">
      <%= form.label :images, class: "block uppercase tracking-wide text-gray-700 text-xs font-bold mb-2" %>
      <%= form.file_field :images, multiple: true, class: "appearance-none block w-full bg-gray-200 text-gray-700 border border-red-500 rounded py-3 px-4 mb-3 leading-tight focus:outline-none focus:bg-white" %>
    </div>

    <div class="md:flex md:items-center">
      <div class="md:w-1/3"></div>
      <div class="md:w-2/3">
        <%= form.submit "Publicar", class: "btn btn-blue" %>
      </div>
    </div>
  </div>
<% end %>
