<div class="flex min-h-full items-center justify-center mx-auto mb-6">
  <div class="w-full max-w-md space-y-8">
    <div>
      <img class="mx-auto h-12 w-auto" src="https://tailwindui.com/img/logos/mark.svg?color=indigo&shade=600" alt="Your Company">
      <h2 class="mt-6 text-center text-3xl font-bold tracking-tight text-gray-900">Bem-vindo(a) ao F de Festa</h2>
    </div>
    <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: {class: "mt-8 space-y-6" }) do |f| %>
      <%= render "devise/shared/error_messages", resource: resource %>

      <div class="-space-y-px rounded-md shadow-sm">
        <div>
          <%= f.label :email, class: "sr-only" %>
          <%= f.email_field :email, autofocus: true, class: "relative block w-full appearance-none rounded-none rounded-t-md border border-gray-300 px-3 py-2 text-gray-900 placeholder-gray-500 focus:z-10 focus:border-violet-500 focus:outline-none focus:ring-violet-500 sm:text-sm", placeholder: "Email" %>
        </div>

        <div>
          <%= f.label "Primeiro Nome", class: "sr-only" %>
            <%= f.text_field :first_name, class: "relative block w-full appearance-none rounded-none rounded-md border border-gray-300 px-3 py-2 text-gray-900 placeholder-gray-500 focus:z-10 focus:border-violet
            -500 focus:outline-none focus:ring-violet-500 sm:text-sm", placeholder: "Primeiro Nome" %>
        </div>

        <div>
          <%= f.label "Último Nome", class: "sr-only" %>
          <%= f.text_field :last_name, class: "relative block w-full appearance-none rounded-none rounded-md border border-gray-300 px-3 py-2 text-gray-900 placeholder-gray-500 focus:z-10 focus:border-violet
            -500 focus:outline-none focus:ring-violet-500 sm:text-sm", placeholder: "Último Nome" %>
        </div>

        <div>
          <%= f.label "Apelido", class: "sr-only" %>
          <%= f.text_field :nickname, class: "relative block w-full appearance-none rounded-none rounded-md border border-gray-300 px-3 py-2 text-gray-900 placeholder-gray-500 focus:z-10 focus:border-violet
            -500 focus:outline-none focus:ring-violet-500 sm:text-sm", placeholder: "Apelido" %>
        </div>

        <div>
          <%= f.label :password, class: "sr-only" %>
          <% if @minimum_password_length %>
            <%= f.password_field :password, autocomplete: "new-password", class: "relative block w-full appearance-none rounded-none rounded-md border border-gray-300 px-3 py-2 text-gray-900 placeholder-gray-500 focus:z-10 focus:border-violet
            -500 focus:outline-none focus:ring-violet-500 sm:text-sm", placeholder: "Password (no mínimo #{@minimum_password_length} caracteres)" %>
          <% end %>
        </div>

        <div>
          <%= f.label :password_confirmation, class: "sr-only" %>
          <%= f.password_field :password, autocomplete: "new-password", class: "relative block w-full appearance-none rounded-none rounded-b-md border border-gray-300 px-3 py-2 text-gray-900 placeholder-gray-500 focus:z-10 focus:border-violet-500 focus:outline-none focus:ring-violet-500 sm:text-sm", placeholder: "Confirmar Password" %>
        </div>
      </div>

      <div class="flex items-center justify-end">
        <div class="text-sm">
          <%= render "devise/shared/links" %>
        </div>
      </div>

      <div>
        <%= f.submit "Registrar", class: "group relative flex w-full justify-center rounded-md border border-transparent bg-violet-600 py-2 px-4 text-sm font-medium text-white hover:bg-violet-700 focus:outline-none focus:ring-2 focus:ring-violet-500 focus:ring-offset-2" %>
      </div>
    <% end %>
  </div>
</div>


