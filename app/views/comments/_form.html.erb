<%= form_with(model: [announcement, announcement.comments.build]) do |f| %>

  <div class="container flex flex-col">
    <div>
      <%= f.text_area :body, class: "block p-2.5 w-full text-sm text-gray-900 bg-gray-50 rounded-lg border border-gray-300 focus:ring-violet-500 focus:border-violet-500 dark:bg-violet-700 dark:border-violet-600 dark:placeholder-violet-400 dark:text-white dark:focus:ring-blue-500 dark:focus:border-blue-500" %>
    </div>
    <div class="mt-2">
      <div class="flex justify-end">
        <%= f.submit "Criar", class: "bg-violet-500 hover:bg-violet-700 text-white font-bold py-2 px-4 rounded-full" %>
      </div>
    </div>
  </div>

<% end %>