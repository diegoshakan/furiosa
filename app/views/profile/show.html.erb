<!--
  This example requires updating your template:

  ```
  <html class="h-full">
  <body class="h-full">
  ```
-->
<div class="flex flex-nowrap mx-auto mb-6 bg-white border border-gray-300 rounded-lg shadow dark:bg-gray-800 dark:border-gray-700">
  <div class="basis-full">
    <div class="text-center">
      <div class="flex flex-col">
        <div>
          <% if current_user&.avatar.attached? %>
            <%= image_tag current_user.avatar, class: "inline-block h-1/4 w-1/4 rounded-full ring-4 ring-violet", style: "width: 10%" %>
          <% else %>
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="inline-block h-1/2 w-1/2 rounded-full">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17.982 18.725A7.488 7.488 0 0012 15.75a7.488 7.488 0 00-5.982 2.975m11.963 0a9 9 0 10-11.963 0m11.963 0A8.966 8.966 0 0112 21a8.966 8.966 0 01-5.982-2.275M15 9.75a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
        <% end %>
        </div>
      </div>
      <div class="flex flex-col">
        <div>
          <h1 class="mt-4 text-3xl font-bold tracking-tight text-gray-900 sm:text-3xl"><%= current_user.full_name %></h1>
        </div>
        <div>
          <p class="text-base leading-7 text-gray-700"><%= current_user.nickname %> - <%= current_user.email %></p>
        </div>
        <div>
          <p class="text-base leading-7 text-gray-700">Telefone: <%= current_user.phone %></p>
        </div>
        <div>
          <p class="text-base leading-7 text-gray-700">Gênero: <%= current_user.gender %></p>
        </div>
        <div>
          <p class="text-base mt-1 leading-relaxed text-gray-400">Anúncios Ativos: <%= current_user.announcements.size %></p>
        </div>
      </div>
      <div class="mt-10 flex items-center justify-center gap-x-6">
        <%= link_to edit_user_registration_path, class: "flex items-center text-sm font-semibold text-blue-900" do %>
          Editar Informações
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6 ml-2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L10.582 16.07a4.5 4.5 0 01-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 011.13-1.897l8.932-8.931zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0115.75 21H5.25A2.25 2.25 0 013 18.75V8.25A2.25 2.25 0 015.25 6H10" />
          </svg>
        <% end %>

      </div>
      <% if current_user.address.present? %>
        <div class="mt-2 mb-2 flex items-center justify-center gap-x-6">
          <%= link_to edit_address_path(current_user.address), class: "flex items-center text-sm font-semibold text-blue-900" do %>
            Editar Endereço
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6 ml-2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L10.582 16.07a4.5 4.5 0 01-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 011.13-1.897l8.932-8.931zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0115.75 21H5.25A2.25 2.25 0 013 18.75V8.25A2.25 2.25 0 015.25 6H10" />
            </svg>
          <% end %>

        </div>
      <% end %>
    </div>
  </div>
</div>
